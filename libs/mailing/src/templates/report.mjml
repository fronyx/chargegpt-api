<mjml>
  <mj-body>
    <mj-section>
      <mj-column background-color="#000045" padding-top="12px" padding-bottom="12px">

        <mj-image width="220px" src="https://cdn.example.com/assets/fronyx-logo.JPG"></mj-image>

        <mj-text font-size="20px" color="white" font-family="helvetica" align="center">Tailored electric vehicle charging decisions</mj-text>

      </mj-column>
    </mj-section>

    <mj-section>
      <mj-column>
        <mj-text color="#000045" font-size="16px">Dear User,</mj-text>
        <mj-text color="#000045" align="center" font-size="16px">2 hours ago, you had requested the predictions of charging stations nearby</mj-text>
        <mj-text font-weight="800" align="center" font-size="16px">Westfalenpark, Dortmund for your arrival time of 12:30</mj-text>
        <mj-text align="center" font-size="16px" padding-top="24px">This is how accurate our predictions are</mj-text>
      </mj-column>
    </mj-section>

    <mj-wrapper background-color="#000045" border-radius="16px">
