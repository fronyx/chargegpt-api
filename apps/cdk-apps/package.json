{
  "name": "cdk-apps",
  "version": "0.1.0",
  "bin": {
    "cdk-apps": "bin/cdk-apps.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "clean": "tsc --build --clean",
    "manage": "./manage.sh",
    "typeorm": "ts-node --project tsconfig.json -r tsconfig-paths/register ../../node_modules/typeorm/cli.js",
    "migration:generate": "npm run typeorm -- migration:generate -d migration.config.ts",
    "migration:run": "npm run typeorm -- migration:run -d migration.config.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d migration.config.ts"
  },
  "devDependencies": {
    "@types/jest": "^26.0.24",
    "@types/jsonwebtoken": "^8.5.9",
    "@types/node": "^10.17.60",
    "@types/uuid": "^9.0.1",
    "@types/validator": "^13.7.12",
    "aws-cdk": "^2.66.1",
    "jest": "^26.4.2",
    "ts-jest": "^26.2.0",
    "ts-loader": "^9.3.0",
    "ts-node": "^10.7.0",
    "typescript": "~4.2.4",
    "webpack": "^5.72.1",
    "webpack-cli": "^4.9.2"
  },
  "dependencies": {
    "@aws-cdk/aws-apigatewayv2-alpha": "^2.61.1-alpha.0",
    "@aws-cdk/aws-apigatewayv2-authorizers-alpha": "^2.61.1-alpha.0",
    "@aws-cdk/aws-apigatewayv2-integrations-alpha": "^2.61.1-alpha.0",
    "@aws-sdk/client-cloudwatch-events": "^3.112.0",
    "@aws-sdk/client-lambda": "^3.118.0",
    "@aws-sdk/client-sqs": "^3.112.0",
    "@sentry/serverless": "^7.2.0",
    "@types/config": "0.0.41",
    "@types/mongoose": "^5.11.97",
    "aws-cdk-lib": "2.61.1",
    "axios": "^0.27.2",
    "axios-retry": "^3.2.5",
    "class-validator": "^0.13.2",
    "config": "^3.3.7",
    "constructs": "^10.0.0",
    "esbuild": "^0.14.39",
    "jsonwebtoken": "^8.5.1",
    "jwks-rsa": "^3.0.1",
    "mongoose": "7.0.0",
    "pg": "^8.7.3",
    "redis": "^4.2.0",
    "source-map-support": "^0.5.16",
    "typeorm": "^0.3.7"
  }
}
